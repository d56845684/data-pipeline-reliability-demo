# LINE Messaging API 設定（複製為 .env 後填入，未設定則告警只輸出 console）
# 取得方式見 README「LINE 告警推播設定」一節

# LINE Developers Console > Messaging API > Channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=

# LINE Developers Console > Basic settings > Channel secret（webhook 簽章驗證用）
LINE_CHANNEL_SECRET=

# 推播目標（userId / groupId）：把 bot 加好友後傳訊息，bot 會回覆你的 ID
LINE_TARGET_ID=

# true 時 RESOLVED 也推播（預設只推 FIRING，節省免費額度 500 則/月）
LINE_SEND_RESOLVED=false
