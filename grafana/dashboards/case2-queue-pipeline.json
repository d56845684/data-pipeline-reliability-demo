{
  "uid": "case2-queue",
  "title": "Case 2 — Multi-tenant Queue Pipeline (RabbitMQ)",
  "tags": ["dataops", "rabbitmq", "multi-tenant"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "佇列深度（chunk 任務積壓）",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rabbitmq_queue_messages{queue=~\"c2\\\\.vector\\\\..*\", queue!=\"c2.vector.dlq\"}", "legendFormat": "{{queue}}", "refId": "A" },
        { "expr": "rabbitmq_queue_messages{queue=\"c2.upload\"}", "legendFormat": "c2.upload", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "unit": "short",
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1000 }] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "各租戶 E2E 延遲 P95（上傳 → 入庫，>60s 告警）",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, tenant) (rate(c2_chunk_e2e_seconds_bucket[5m])))",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "thresholdsStyle": { "mode": "dashed" } },
          "unit": "s",
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 60 }] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Chunk 處理速率（by tenant）",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (tenant) (rate(c2_chunks_processed_total[1m]))", "legendFormat": "{{tenant}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "ops",
          "min": 0
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DLQ 深度（>0 即 critical）",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rabbitmq_queue_messages{queue=\"c2.vector.dlq\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "冪等跳過（重複投遞）",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(c2_duplicates_skipped_total)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "DB 寫入批次大小（batch vs 逐筆）",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(c2_db_batch_rows_sum[1m]) / rate(c2_db_batch_rows_count[1m])",
          "legendFormat": "平均每 flush 筆數",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "上傳量（files/min by tenant）",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (tenant) (rate(c2_files_split_total[1m])) * 60", "legendFormat": "{{tenant}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}
